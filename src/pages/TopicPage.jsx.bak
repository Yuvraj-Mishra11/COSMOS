import { useParams, useNavigate } from 'react-router-dom';
import { useState, useEffect } from 'react';
import { generateTopicContent } from '../utils/search';
import StarBackground from '../components/StarBackground';

const TopicPage = () => {
  const { topicId } = useParams();
  const navigate = useNavigate();
  const [topic, setTopic] = useState(null);
  const [isLoading, setIsLoading] = useState(false);
  const [loadingMessage, setLoadingMessage] = useState('');

  const topics = {
    'black-holes': {
      title: 'Black Holes',
      subtitle: 'The mysterious regions of spacetime',
      overview: 'Black holes are regions of spacetime where gravity is so intense that nothing, not even light, can escape.',
      timeline: [],
      concepts: [{ name: 'Event Horizon', description: 'The boundary where nothing can escape.' }],
      facts: ['The nearest black hole is 1,500 light-years away.']
    }
  };

  useEffect(() => {
    const loadTopic = async () => {
      if (topics[topicId]) {
        setTopic(topics[topicId]);
        return;
      }

      setIsLoading(true);
      setLoadingMessage('🔍 Starting research...');

      try {
        const aiContent = await generateTopicContent(
          topicId,
          topicId.replace(/-/g, ' '),
          (msg) => setLoadingMessage(msg)
        );
        setTopic(aiContent);
      } catch (error) {
        setTopic({
          title: topicId.replace(/-/g, ' '),
          subtitle: 'Search unavailable',
          overview: 'Please try again later.',
          timeline: [],
          concepts: [],
          facts: ['Search is temporarily unavailable.']
        });
      }
      setIsLoading(false);
    };

    loadTopic();
  }, [topicId]);

  if (isLoading) {
    return (
      <>
        <StarBackground />
        <CursorParticles />
        <div style={{
          background: '#0a0a0a',
          minHeight: '100vh',
          display: 'flex',
          flexDirection: 'column',
          alignItems: 'center',
          justifyContent: 'center',
          fontFamily: 'Inter, sans-serif',
          padding: '2rem',
          position: 'relative',
          zIndex: 1
        }}>
          {/* Animated rings */}
          <div style={{
            width: '80px',
            height: '80px',
            position: 'relative',
            marginBottom: '2rem'
          }}>
            <div style={{
              position: 'absolute',
              inset: 0,
              borderRadius: '50%',
              border: '1px solid rgba(255,255,255,0.05)',
              animation: 'pulse-ring 2s ease-out infinite'
            }} />
            <div style={{
              position: 'absolute',
              inset: '10px',
              borderRadius: '50%',
              border: '1px solid rgba(255,255,255,0.08)',
              animation: 'pulse-ring 2s ease-out infinite 0.5s'
            }} />
            <div style={{
              position: 'absolute',
              inset: '20px',
              borderRadius: '50%',
              border: '1px solid rgba(255,255,255,0.12)',
              animation: 'pulse-ring 2s ease-out infinite 1s'
            }} />
            <div style={{
              position: 'absolute',
              inset: '30px',
              borderRadius: '50%',
              border: '1px solid rgba(255,255,255,0.15)',
              animation: 'pulse-ring 2s ease-out infinite 1.5s'
            }} />
          </div>
          <p style={{
            color: '#888899',
            fontSize: '0.9rem',
            letterSpacing: '0.15em',
            fontWeight: 300
          }}>
            {loadingMessage || 'Researching...'}
          </p>
          <style>{`
            @keyframes pulse-ring {
              0% { transform: scale(0.8); opacity: 1; }
              100% { transform: scale(1.5); opacity: 0; }
            }
          `}</style>
        </div>
      </>
    );
  }

  if (!topic) {
    return (
      <>
        <StarBackground />
        <CursorParticles />
        <div style={{
          background: '#0a0a0a',
          minHeight: '100vh',
          display: 'flex',
          alignItems: 'center',
          justifyContent: 'center',
          fontFamily: 'Inter, sans-serif',
          position: 'relative',
          zIndex: 1
        }}>
          <p style={{ color: '#888899' }}>Loading...</p>
        </div>
      </>
    );
  }

  return (
    <>
      <style>{`
        @keyframes glassFadeIn {
          0% {
            opacity: 0;
            transform: translateY(30px) scale(0.98);
          }
          100% {
            opacity: 1;
            transform: translateY(0) scale(1);
          }
        }
        .cosmos-glass-panel {
          animation: glassFadeIn 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
        }
        @keyframes shimmer {
          0% { left: -100%; }
          100% { left: 200%; }
        }
        ${[...Array(12)].map((_, i) => `
          @keyframes float-particle-${i} {
            0% {
              transform: translate(0, 0) scale(1);
              opacity: ${Math.random() * 0.3 + 0.1};
            }
            25% {
              transform: translate(${Math.random() * 40 - 20}px, ${Math.random() * 40 - 20}px) scale(1.2);
              opacity: ${Math.random() * 0.5 + 0.2};
            }
            50% {
              transform: translate(${Math.random() * 40 - 20}px, ${Math.random() * 40 - 20}px) scale(0.8);
              opacity: ${Math.random() * 0.2 + 0.1};
            }
            75% {
              transform: translate(${Math.random() * 40 - 20}px, ${Math.random() * 40 - 20}px) scale(1.1);
              opacity: ${Math.random() * 0.4 + 0.1};
            }
            100% {
              transform: translate(0, 0) scale(1);
              opacity: ${Math.random() * 0.3 + 0.1};
            }
          }
        `).join('')}
      `}</style>
      <StarBackground />
      <div style={{
        background: 'transparent',
        color: '#ffffff',
        minHeight: '100vh',
        fontFamily: 'Inter, sans-serif',
        padding: '2rem 3rem',
        position: 'relative',
        zIndex: 1,
        display: 'flex',
        justifyContent: 'center',
        alignItems: 'flex-start'
      }}>
        <div className="cosmos-glass-panel" style={{
          padding: '1px',
          borderRadius: '24px',
          background: 'linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.01), rgba(255,255,255,0.05))',
          maxWidth: '1100px',
          width: '100%',
          margin: '0 auto',
          boxShadow: '0 20px 60px rgba(0, 0, 0, 0.5)'
        }}>
          <div style={{
            maxWidth: '1100px',
            width: '100%',
            margin: '0 auto',
            background: 'rgba(255, 255, 255, 0.015)',
            backdropFilter: 'blur(12px) saturate(1.1)',
            WebkitBackdropFilter: 'blur(12px) saturate(1.1)',
            borderRadius: '24px',
            border: '1px solid rgba(255, 255, 255, 0.04)',
            boxShadow: 'inset 0 1px 0 rgba(255, 255, 255, 0.05)',
            padding: '2rem 3rem',
            position: 'relative',
            overflow: 'hidden'
          }}>

          {/* Floating particles inside glass */}
          <div style={{
            position: 'absolute',
            top: 0,
            left: 0,
            width: '100%',
            height: '100%',
            pointerEvents: 'none',
            overflow: 'hidden',
            zIndex: 0
          }}>
            {[...Array(12)].map((_, i) => (
              <div
                key={i}
                style={{
                  position: 'absolute',
                  width: `${Math.random() * 3 + 1}px`,
                  height: `${Math.random() * 3 + 1}px`,
                  borderRadius: '50%',
                  background: 'rgba(255,255,255,0.15)',
                  top: `${Math.random() * 100}%`,
                  left: `${Math.random() * 100}%`,
                  animation: `float-particle-${i} ${15 + Math.random() * 20}s ease-in-out infinite ${Math.random() * 5}s`,
                  opacity: Math.random() * 0.3 + 0.1
                }}
              />
            ))}
          </div>
          
          {/* Shimmering light effect */}
          <div style={{
            position: 'absolute',
            top: 0,
            left: '-100%',
            width: '60%',
            height: '100%',
            background: 'linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent)',
            transform: 'skewX(-25deg)',
            animation: 'shimmer 8s ease-in-out infinite',
            pointerEvents: 'none'
          }} />

          {/* Inner glow - subtle light effect */}
          <div style={{
            position: 'absolute',
            top: '-30%',
            right: '-20%',
            width: '50%',
            height: '70%',
            background: 'radial-gradient(ellipse, rgba(255,255,255,0.03), transparent 70%)',
            pointerEvents: 'none',
            borderRadius: '50%'
          }} />

          {/* Second glow - bottom left */}
          <div style={{
            position: 'absolute',
            bottom: '-20%',
            left: '-10%',
            width: '40%',
            height: '50%',
            background: 'radial-gradient(ellipse, rgba(100,150,255,0.02), transparent 70%)',
            pointerEvents: 'none',
            borderRadius: '50%'
          }} />

          <div style={{
            position: 'absolute',
            top: 0,
            left: '10%',
            width: '80%',
            height: '1px',
            background: 'linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent)',
            pointerEvents: 'none'
          }} />

          <div style={{
            position: 'absolute',
            bottom: 0,
            left: '10%',
            width: '80%',
            height: '1px',
            background: 'linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent)',
            pointerEvents: 'none'
          }} />

          {/* Corner glow - top right */}
          <div style={{
            position: 'absolute',
            top: '-60px',
            right: '-60px',
            width: '200px',
            height: '200px',
            background: 'radial-gradient(circle, rgba(255,255,255,0.04), transparent 70%)',
            borderRadius: '50%',
            pointerEvents: 'none'
          }} />

          {/* Corner glow - bottom left */}
          <div style={{
            position: 'absolute',
            bottom: '-60px',
            left: '-60px',
            width: '200px',
            height: '200px',
            background: 'radial-gradient(circle, rgba(100,150,255,0.03), transparent 70%)',
            borderRadius: '50%',
            pointerEvents: 'none'
          }} />

          {/* Subtle vignette effect */}
          <div style={{
            position: 'absolute',
            inset: 0,
            background: 'radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.1) 100%)',
            pointerEvents: 'none',
            borderRadius: '24px'
          }} />
          
          {/* Back Button */}
          <button
            onClick={() => navigate('/')}
            style={{
              background: 'none',
              border: 'none',
              color: '#555',
              fontSize: '0.85rem',
              cursor: 'pointer',
              fontFamily: 'Inter, sans-serif',
              letterSpacing: '0.1em',
              padding: '0.5rem 0',
              marginBottom: '1.5rem',
              transition: 'color 0.3s ease',
              position: 'relative',
              zIndex: 2
            }}
            onMouseEnter={(e) => e.target.style.color = '#888'}
            onMouseLeave={(e) => e.target.style.color = '#555'}
          >
            ← Back
          </button>

          {/* Hero Section */}
          <div style={{
            padding: '2rem 0 3rem 0',
            borderBottom: '1px solid rgba(255,255,255,0.04)',
            position: 'relative',
            zIndex: 2
          }}>
            {/* Letter Icon with glass effect */}
            <div style={{
              width: '72px',
              height: '72px',
              borderRadius: '50%',
              background: 'rgba(255,255,255,0.05)',
              border: '1px solid rgba(255,255,255,0.08)',
              backdropFilter: 'blur(10px)',
              display: 'flex',
              alignItems: 'center',
              justifyContent: 'center',
              fontSize: '2rem',
              fontWeight: 300,
              color: '#ffffff',
              letterSpacing: '0.05em',
              marginBottom: '1.5rem'
            }}>
              {topic.title?.charAt(0).toUpperCase() || '?'}
            </div>

            <h1 style={{
              fontSize: '4.5rem',
              fontWeight: 200,
              margin: '0 0 0.3rem 0',
              letterSpacing: '-0.02em',
              background: 'linear-gradient(180deg, #ffffff 60%, rgba(255,255,255,0.5))',
              WebkitBackgroundClip: 'text',
              WebkitTextFillColor: 'transparent',
              backgroundClip: 'text'
            }}>
              {topic.title}
            </h1>

            <p style={{
              fontSize: '1.1rem',
              color: 'rgba(255,255,255,0.4)',
              fontWeight: 300,
              letterSpacing: '0.05em'
            }}>
              {topic.subtitle || 'Explore this topic'}
            </p>
          </div>

          {/* Overview */}
          {topic.overview && (
            <div style={{ padding: '3rem 0', borderBottom: '1px solid rgba(255,255,255,0.04)', position: 'relative', zIndex: 2 }}>
              <h2 style={{
                fontSize: '1.2rem',
                fontWeight: 400,
                letterSpacing: '0.2em',
                textTransform: 'uppercase',
                color: 'rgba(255,255,255,0.25)',
                marginBottom: '1.5rem'
              }}>
                Overview
              </h2>
              <p style={{
                fontSize: '1.1rem',
                lineHeight: '1.9',
                color: 'rgba(255,255,255,0.7)',
                fontWeight: 300,
                maxWidth: '90%'
              }}>
                {topic.overview}
              </p>
            </div>
          )}

          {/* Key Concepts */}
          {topic.concepts && topic.concepts.length > 0 && (
            <div style={{ padding: '3rem 0', borderBottom: '1px solid rgba(255,255,255,0.04)', position: 'relative', zIndex: 2 }}>
              <h2 style={{
                fontSize: '1.2rem',
                fontWeight: 400,
                letterSpacing: '0.2em',
                textTransform: 'uppercase',
                color: 'rgba(255,255,255,0.25)',
                marginBottom: '1.5rem'
              }}>
                Key Concepts
              </h2>
              <div style={{
                display: 'grid',
                gridTemplateColumns: '1fr 1fr',
                gap: '1.2rem'
              }}>
                {topic.concepts.map((item, i) => (
                  <div key={i} style={{
                    padding: '1.2rem 1.5rem',
                    background: 'rgba(255, 255, 255, 0.02)',
                    borderRadius: '12px',
                    border: '1px solid rgba(255, 255, 255, 0.03)',
                    backdropFilter: 'blur(10px)',
                    transition: 'all 0.3s ease'
                  }}
                  onMouseEnter={(e) => {
                    e.target.style.background = 'rgba(255,255,255,0.06)';
                    e.target.style.borderColor = 'rgba(255,255,255,0.1)';
                  }}
                  onMouseLeave={(e) => {
                    e.target.style.background = 'rgba(255,255,255,0.03)';
                    e.target.style.borderColor = 'rgba(255,255,255,0.04)';
                  }}>
                    <h3 style={{
                      fontSize: '1rem',
                      fontWeight: 400,
                      color: '#ffffff',
                      marginBottom: '0.4rem'
                    }}>
                      {item.name}
                    </h3>
                    <p style={{
                      fontSize: '0.9rem',
                      color: 'rgba(255,255,255,0.55)',
                      lineHeight: '1.6',
                      fontWeight: 300
                    }}>
                      {item.description}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Important Facts */}
          {topic.facts && topic.facts.length > 0 && (
            <div style={{ padding: '3rem 0', borderBottom: '1px solid rgba(255,255,255,0.04)', position: 'relative', zIndex: 2 }}>
              <h2 style={{
                fontSize: '1.2rem',
                fontWeight: 400,
                letterSpacing: '0.2em',
                textTransform: 'uppercase',
                color: 'rgba(255,255,255,0.25)',
                marginBottom: '1.5rem'
              }}>
                Important Facts
              </h2>
              <div style={{ display: 'grid', gap: '0.6rem' }}>
                {topic.facts.map((fact, i) => (
                  <div key={i} style={{
                    padding: '0.8rem 1.2rem',
                    background: 'rgba(255, 255, 255, 0.01)',
                    borderRadius: '8px',
                    border: '1px solid rgba(255, 255, 255, 0.02)',
                    display: 'flex',
                    gap: '1rem',
                    alignItems: 'flex-start',
                    backdropFilter: 'blur(5px)'
                  }}>
                    <span style={{
                      color: 'rgba(255,255,255,0.2)',
                      fontSize: '0.8rem',
                      fontWeight: 400,
                      minWidth: '28px',
                      letterSpacing: '0.05em'
                    }}>
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <span style={{
                      fontSize: '0.95rem',
                      color: 'rgba(255,255,255,0.6)',
                      lineHeight: '1.6',
                      fontWeight: 300
                    }}>
                      {fact}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Related Articles */}
          {topic.articles && topic.articles.length > 0 && (
            <div style={{ padding: '3rem 0', borderBottom: '1px solid rgba(255,255,255,0.04)', position: 'relative', zIndex: 2 }}>
              <h2 style={{
                fontSize: '1.2rem',
                fontWeight: 400,
                letterSpacing: '0.2em',
                textTransform: 'uppercase',
                color: 'rgba(255,255,255,0.25)',
                marginBottom: '1.5rem'
              }}>
                Related Articles
              </h2>
              <div style={{ display: 'grid', gap: '0.6rem' }}>
                {topic.articles.map((article, i) => (
                  <a
                    key={i}
                    href={article.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    style={{
                      display: 'flex',
                      alignItems: 'center',
                      gap: '1rem',
                      padding: '0.8rem 1.2rem',
                      background: 'rgba(255, 255, 255, 0.01)',
                      border: '1px solid rgba(255, 255, 255, 0.02)',
                      borderRadius: '8px',
                      color: 'rgba(255,255,255,0.6)',
                      textDecoration: 'none',
                      transition: 'all 0.3s ease',
                      fontSize: '0.95rem',
                      fontWeight: 300,
                      backdropFilter: 'blur(5px)'
                    }}
                    onMouseEnter={(e) => {
                      e.target.style.background = 'rgba(255,255,255,0.06)';
                      e.target.style.borderColor = 'rgba(255,255,255,0.1)';
                      e.target.style.color = '#ffffff';
                    }}
                    onMouseLeave={(e) => {
                      e.target.style.background = 'rgba(255,255,255,0.02)';
                      e.target.style.borderColor = 'rgba(255,255,255,0.04)';
                      e.target.style.color = 'rgba(255,255,255,0.6)';
                    }}
                  >
                    <span style={{
                      fontSize: '0.7rem',
                      color: 'rgba(255,255,255,0.2)',
                      minWidth: '70px',
                      letterSpacing: '0.05em',
                      textTransform: 'uppercase'
                    }}>
                      {article.source || 'Source'}
                    </span>
                    <span style={{ flex: 1 }}>{article.title}</span>
                    <span style={{ color: 'rgba(255,255,255,0.2)' }}>→</span>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Related Topics */}
          {topic.relatedTopics && topic.relatedTopics.length > 0 && (
            <div style={{ padding: '3rem 0', position: 'relative', zIndex: 2 }}>
              <h2 style={{
                fontSize: '1.2rem',
                fontWeight: 400,
                letterSpacing: '0.2em',
                textTransform: 'uppercase',
                color: 'rgba(255,255,255,0.25)',
                marginBottom: '1.5rem'
              }}>
                Related Topics
              </h2>
              <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.6rem' }}>
                {topic.relatedTopics.map((t, i) => (
                  <span
                    key={i}
                    onClick={() => navigate(`/topic/${t.toLowerCase().replace(/\s+/g, '-')}`)}
                    style={{
                      padding: '0.4rem 1.2rem',
                      background: 'rgba(255, 255, 255, 0.02)',
                      border: '1px solid rgba(255, 255, 255, 0.04)',
                      borderRadius: '50px',
                      fontSize: '0.85rem',
                      color: 'rgba(255,255,255,0.5)',
                      cursor: 'pointer',
                      transition: 'all 0.3s ease',
                      fontFamily: 'Inter, sans-serif',
                      fontWeight: 300,
                      letterSpacing: '0.02em',
                      backdropFilter: 'blur(5px)'
                    }}
                    onMouseEnter={(e) => {
                      e.target.style.background = 'rgba(255,255,255,0.08)';
                      e.target.style.borderColor = 'rgba(255,255,255,0.15)';
                      e.target.style.color = '#ffffff';
                    }}
                    onMouseLeave={(e) => {
                      e.target.style.background = 'rgba(255,255,255,0.03)';
                      e.target.style.borderColor = 'rgba(255,255,255,0.06)';
                      e.target.style.color = 'rgba(255,255,255,0.5)';
                    }}
                  >
                    {t}
                  </span>
                ))}
              </div>
            </div>
          )}

          {/* Footer */}
          <div style={{
            padding: '2rem 0',
            textAlign: 'center',
            borderTop: '1px solid rgba(255,255,255,0.03)',
            color: 'rgba(255,255,255,0.15)',
            fontSize: '0.8rem',
            fontWeight: 300,
            letterSpacing: '0.1em',
            position: 'relative',
            zIndex: 2
          }}>
            Knowledge should be explored, not just read.
          </div>
        </div>
        </div>
      </div>
    </>
  );
};

export default TopicPage;
